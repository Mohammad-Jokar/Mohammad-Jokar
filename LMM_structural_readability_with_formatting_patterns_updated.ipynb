        "- `ChatBot`"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "required_columns = [\"ChatbotResponseText\", \"ScenarioID\", \"BlindedResponseID\", \"ChatBot\"]\n",
        "missing_columns = [col for col in required_columns if col not in df.columns]\n",
        "\n",
        "if missing_columns:\n",
        "    raise ValueError(\n",
        "        f\"Missing required columns: {missing_columns}\\n\\n\"\n",
        "        f\"Available columns: {df.columns.tolist()}\"\n",
        "    )\n",
        "\n",
        "print(\"All required columns found:\")\n",
        "for col in required_columns:\n",
        "    print(f\"  ✓ {col}\")"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 3. Important: Text is used AS-IS\n",
        "\n",
        "**This version uses the ChatbotResponseText column exactly as provided - NO cleaning or modification.**\n",
        "\n",
        "All metrics will be calculated on the original text, including any formatting, spacing, or special characters."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Copy the response text as-is, without any modification\n",
        "df[\"response_text_original\"] = df[\"ChatbotResponseText\"].copy()\n",
        "\n",
        "print(\"Response text copied without modification.\")\n",
        "print(f\"\\nFirst response (preview - first 200 characters):\")\n",
        "print(df[\"response_text_original\"].iloc[0][:200])"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 4. Length metrics\n",
        "\n",
        "This section defines functions for:\n",
        "\n",
        "- word count\n",
        "- sentence count\n",
        "- paragraph count\n",
        "- average words per sentence\n",
        "\n",
        "These are objective structural metrics describing the length and basic form of each chatbot response.\n",
        "\n",
        "**Text is processed exactly as provided - no cleaning applied.**"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "def count_words(text):\n",
        "    \"\"\"\n",
        "    Count words in the response.\n",
        "    Text is processed as-is without modification.\n",
        "    \"\"\"\n",
        "    if pd.isna(text):\n",
        "        return 0\n",
        "    \n",
        "    text = str(text)\n",
        "    words = re.findall(r\"\\b[\\w']+\\b\", text)\n",
        "    return len(words)\n",
        "\n",
        "\n",
        "def count_sentences(text):\n",
        "    \"\"\"\n",
        "    Count sentences using punctuation-based splitting.\n",
        "    Text is processed as-is without modification.\n",
        "    \"\"\"\n",
        "    if pd.isna(text):\n",
        "        return 0\n",
        "    \n",
        "    text = str(text)\n",
        "    \n",
        "    if not text.strip():\n",
        "        return 0\n",
        "    \n",
        "    sentences = re.split(r\"[.!?]+\", text)\n",
        "    sentences = [s.strip() for s in sentences if s.strip()]\n",
        "    \n",
        "    return len(sentences)\n",
        "\n",
        "\n",
        "def count_paragraphs(text):\n",
        "    \"\"\"\n",
        "    Count paragraphs based on blank lines.\n",
        "    If text exists but there are no blank lines, the response is counted as one paragraph.\n",
        "    Text is processed as-is without modification.\n",
        "    \"\"\"\n",
        "    if pd.isna(text):\n",
        "        return 0\n",
        "    \n",
        "    text = str(text)\n",
        "    \n",
        "    if not text.strip():\n",
        "        return 0\n",
        "    \n",
        "    paragraphs = re.split(r\"\\n\\s*\\n\", text)\n",
        "    paragraphs = [p.strip() for p in paragraphs if p.strip()]\n",
        "    \n",
        "    return len(paragraphs)\n",
        "\n",
        "\n",
        "def average_words_per_sentence(text):\n",
        "    \"\"\"\n",
        "    Calculate average words per sentence.\n",
        "    \"\"\"\n",
        "    words = count_words(text)\n",
        "    sentences = count_sentences(text)\n",
        "    \n",
        "    if sentences == 0:\n",
        "        return None\n",
        "    \n",
        "    return round(words / sentences, 2)"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 5. Formatting metrics based on predefined patterns/symbols\n",
        "\n",
        "This section detects whether the chatbot response includes:\n",
        "\n",
        "- headings\n",
        "- bullet points or numbered lists\n",
        "- stepwise instructions\n",
        "\n",
        "These are coded as `yes` or `no`.\n",
        "\n",
        "These variables depend on predefined formatting patterns/symbols and should be manually reviewed after automatic detection."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "def detect_bullets_or_numbered_list(text):\n",
        "    \"\"\"\n",
        "    Detect bullet points or numbered lists.\n",
        "\n",
        "    Examples detected:\n",
        "    - item\n",
        "    * item\n",
        "    • item\n",
        "    1. item\n",
        "    1) item\n",
        "    a) item\n",
        "    \"\"\"\n",
        "    if pd.isna(text):\n",
        "        return \"no\"\n",
        "    \n",
        "    text = str(text)\n",
        "    bullet_pattern = r\"(^|\\n)\\s*([-*•]|\\d+[.)]|[a-zA-Z][.)])\\s+\"\n",
        "    \n",
        "    if re.search(bullet_pattern, text):\n",
        "        return \"yes\"\n",
        "    else:\n",
        "        return \"no\"\n",
        "\n",
        "\n",
        "def detect_headings(text):\n",
        "    \"\"\"\n",
        "    Detect likely headings based on visible formatting patterns.\n",
        "\n",
        "    Examples detected:\n",
        "    Emergency Advice:\n",
        "    IMPORTANT\n",
        "    ## Emergency Advice\n",
        "    \"\"\"\n",
        "    if pd.isna(text):\n",
        "        return \"no\"\n",
        "    \n",
        "    text = str(text)\n",
        "    \n",
        "    if not text.strip():\n",
        "        return \"no\"\n",
        "    \n",
        "    lines = text.split(\"\\n\")\n",
        "    \n",
        "    for line in lines:\n",
        "        line_clean = line.strip()\n",
        "        \n",
        "        if not line_clean:\n",
        "            continue\n",
        "        \n",
        "        word_count = len(line_clean.split())\n",
        "        \n",
        "        # Markdown-style heading\n",
        "        if re.match(r\"^#{1,6}\\s+\", line_clean):\n",
        "            return \"yes\"\n",
        "        \n",
        "        # Short line ending with colon\n",
        "        if word_count <= 10 and line_clean.endswith(\":\"):\n",
        "            return \"yes\"\n",
        "        \n",
        "        # Short uppercase line\n",
        "        if word_count <= 10 and line_clean.isupper() and len(line_clean) > 2:\n",
        "            return \"yes\"\n",
        "    \n",
        "    return \"no\"\n",
        "\n",
        "\n",
        "def detect_stepwise_instructions(text):\n",
        "    \"\"\"\n",
        "    Detect whether the response contains stepwise instructions.\n",
        "\n",
        "    This variable depends on predefined step/list patterns and should be manually reviewed.\n",
        "    \"\"\"\n",
        "    if pd.isna(text):\n",
        "        return \"no\"\n",
        "    \n",
        "    text_original = str(text)\n",
        "    text_lower = text_original.lower()\n",
        "    \n",
        "    if not text_lower.strip():\n",
        "        return \"no\"\n",
        "    \n",
        "    step_patterns = [\n",
        "        r\"\\bstep\\s*1\\b\",\n",
        "        r\"\\bstep\\s*2\\b\",\n",
        "        r\"\\bfirst\\b\",\n",
        "        r\"\\bsecond\\b\",\n",
        "        r\"\\bthird\\b\",\n",
        "        r\"\\bnext\\b\",\n",
        "        r\"\\bthen\\b\",\n",
        "        r\"\\bfinally\\b\",\n",
        "        r\"\\bimmediately\\b.*\\bthen\\b\",\n",
        "        r\"(^|\\n)\\s*1[.)]\\s+\",\n",
        "        r\"(^|\\n)\\s*2[.)]\\s+\",\n",
        "        r\"(^|\\n)\\s*3[.)]\\s+\"\n",
        "    ]\n",
        "    \n",
        "    for pattern in step_patterns:\n",
        "        if re.search(pattern, text_lower):\n",
        "            return \"yes\"\n",
        "    \n",
        "    return \"no\""
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 6. Readability metrics\n",
        "\n",
        "This section calculates:\n",
        "\n",
        "- Flesch Reading Ease\n",
        "- Flesch-Kincaid Grade Level\n",
        "\n",
        "The formulas require:\n",
        "\n",
        "- number of words\n",
        "- number of sentences\n",
        "- number of syllables\n",
        "\n",
        "A lower Flesch-Kincaid Grade Level generally means easier reading. A higher Flesch Reading Ease score generally means easier reading.\n",
        "\n",
        "These metrics should be interpreted only as measures of readability, not clinical accuracy or safety."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "def count_syllables_in_word(word):\n",
        "    \"\"\"\n",
        "    Approximate syllable count for English words.\n",
        "    This approach is not perfect, but it is suitable for automated readability estimates.\n",
        "    \"\"\"\n",
        "    word = word.lower()\n",
        "    word = re.sub(r\"[^a-z]\", \"\", word)\n",
        "    \n",
        "    if len(word) == 0:\n",
        "        return 0\n",
        "    \n",
        "    vowels = \"aeiouy\"\n",
        "    syllables = 0\n",
        "    previous_char_was_vowel = False\n",
        "    \n",
        "    for char in word:\n",
        "        current_char_is_vowel = char in vowels\n",
        "        \n",
        "        if current_char_is_vowel and not previous_char_was_vowel:\n",
        "            syllables += 1\n",
        "        \n",
        "        previous_char_was_vowel = current_char_is_vowel\n",
        "    \n",
        "    # Adjust for silent final \"e\"\n",
        "    if word.endswith(\"e\") and syllables > 1:\n",
        "        syllables -= 1\n",
        "    \n",
        "    return max(syllables, 1)\n",
        "\n",
        "\n",
        "def count_total_syllables(text):\n",
        "    \"\"\"\n",
        "    Count total syllables in the response.\n",
        "    \"\"\"\n",
        "    if pd.isna(text):\n",
        "        return 0\n",
        "    \n",
        "    text = str(text)\n",
        "    words = re.findall(r\"\\b[a-zA-Z]+\\b\", text)\n",
        "    \n",
        "    total = sum(count_syllables_in_word(word) for word in words)\n",
        "    \n",
        "    return total\n",
        "\n",
        "\n",
        "def flesch_reading_ease(text):\n",
        "    \"\"\"\n",
        "    Calculate Flesch Reading Ease.\n",
        "    Higher scores indicate easier reading.\n",
        "    \"\"\"\n",
        "    words = count_words(text)\n",
        "    sentences = count_sentences(text)\n",
        "    syllables = count_total_syllables(text)\n",
        "    \n",
        "    if words == 0 or sentences == 0:\n",
        "        return None\n",
        "    \n",
        "    score = 206.835 - 1.015 * (words / sentences) - 84.6 * (syllables / words)\n",
        "    \n",
        "    return round(score, 2)\n",
        "\n",
        "\n",
        "def flesch_kincaid_grade(text):\n",
        "    \"\"\"\n",
        "    Calculate Flesch-Kincaid Grade Level.\n",
        "    Lower scores indicate easier reading.\n",
        "    \"\"\"\n",
        "    words = count_words(text)\n",
        "    sentences = count_sentences(text)\n",
        "    syllables = count_total_syllables(text)\n",
        "    \n",
        "    if words == 0 or sentences == 0:\n",
        "        return None\n",
        "    \n",
        "    grade = 0.39 * (words / sentences) + 11.8 * (syllables / words) - 15.59\n",
        "    \n",
        "    return round(grade, 2)"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 7. Calculate all metrics\n",
        "\n",
        "This section applies the functions to every chatbot response in the dataset.\n",
        "\n",
        "The notebook creates the following new columns:\n",
        "\n",
        "- `word_count`\n",
        "- `sentence_count`\n",
        "- `paragraph_count`\n",
        "- `avg_words_per_sentence`\n",
        "- `has_headings`\n",
        "- `has_bullets_or_numbered_list`\n",
        "- `has_stepwise_instructions`\n",
        "- `flesch_reading_ease`\n",
        "- `flesch_kincaid_grade`\n",
        "- `manual_review_notes`"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Calculate metrics on the original text (as-is, no modification)\n",
        "df[\"word_count\"] = df[\"response_text_original\"].apply(count_words)\n",
        "df[\"sentence_count\"] = df[\"response_text_original\"].apply(count_sentences)\n",
        "df[\"paragraph_count\"] = df[\"response_text_original\"].apply(count_paragraphs)\n",
        "df[\"avg_words_per_sentence\"] = df[\"response_text_original\"].apply(average_words_per_sentence)\n",
        "\n",
        "# Formatting metrics based on predefined patterns/symbols\n",
        "df[\"has_headings\"] = df[\"response_text_original\"].apply(detect_headings)\n",
        "df[\"has_bullets_or_numbered_list\"] = df[\"response_text_original\"].apply(detect_bullets_or_numbered_list)\n",
        "df[\"has_stepwise_instructions\"] = df[\"response_text_original\"].apply(detect_stepwise_instructions)\n",
        "\n",
        "# Readability metrics\n",
        "df[\"flesch_reading_ease\"] = df[\"response_text_original\"].apply(flesch_reading_ease)\n",
        "df[\"flesch_kincaid_grade\"] = df[\"response_text_original\"].apply(flesch_kincaid_grade)\n",
        "\n",
        "# Add manual review column\n",
        "df[\"manual_review_notes\"] = \"\"\n",
        "\n",
        "print(\"Metrics calculated successfully.\")\n",
        "print(f\"Number of responses processed: {len(df)}\")"
      ]
    },
