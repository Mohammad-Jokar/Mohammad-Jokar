        "print(\"\\nColumns in file:\")\n",
        "print(df.columns.tolist())"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 2. Check required columns\n",
        "\n",
        "The notebook needs these columns:\n",
        "- `ChatbotResponseText`\n",
