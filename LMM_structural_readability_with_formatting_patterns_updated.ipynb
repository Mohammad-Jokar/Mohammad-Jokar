        "2. The file name matches what you specified above.\n",
        "3. The file extension is `.xlsx`.\n",
        "4. The file is not open or locked by Excel."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "if not input_file.exists():\n",
